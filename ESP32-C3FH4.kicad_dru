(version 1)
(rule "ESP32_Tight_Pitch"
    (constraint clearance (min 0.12mm))
    (constraint track_width (min 0.12mm))
    (condition "A.insideArea('ESP_CLR')"))
(rule "USB_CLEARENCE"
    (constraint clearance (min 0.12mm))
    (constraint track_width (min 0.12mm))
    (condition "A.insideArea('USB_CLR')"))
(rule "USB_CRS1"
    (constraint clearance (min 0.12mm))
    (constraint track_width (min 0.12mm))
    (condition "A.insideArea('USBIC_CLR')"))
